# ==================== Общие настройки ====================
CUDA_VISIBLE_DEVICES=0
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
SHM_SIZE=16g

# ==================== Версии сборки ====================
CUDA_VER=12.9.0
PYTORCH_CUDA_TAG=cu129
FISH_SPEECH_REF=main

# ==================== Порты ====================
FRONTEND_PORT=7070
GATEWAY_PORT=7777
RENDER_PORT=7778
LIVE_PORT=7779
PREPROCESS_PORT=7780
FINETUNE_PORT=7781

# ==================== Пути (внутри контейнеров) ====================
MODEL_REPO=fishaudio/s2-pro
MODEL_PATH=/app/data/checkpoints/s2-pro
LIVE_MODEL_PATH=/app/data/live_engine/s2-pro-q8_0.gguf

# ==================== RENDER (высокое качество) ====================
ENABLE_COMPILE=false
RENDER_STACK_ENABLE_COMPILE=true
RENDER_STACK_CHUNK_LENGTH=240
DTYPE=bfloat16
DEVICE=cuda
MAX_TEXT_LENGTH=1500
CHUNK_LENGTH=240
NORMALIZE_TEXT=true
USE_MEMORY_CACHE=on
TEMPERATURE=0.62
TOP_P=0.88
REPETITION_PENALTY=1.15
SEED=42

# ==================== LIVE (streaming) ====================
LIVE_ENGINE=s2cpp
S2CPP_BIN=/app/data/live_engine/s2
S2CPP_TOKENIZER_PATH=/app/data/live_engine/tokenizer.json
S2CPP_EXTRA_ARGS=

# ==================== Fine-tuning ====================
FINETUNE_BASE_MODEL=/app/data/checkpoints/s2-pro
FINETUNE_DATA_DIR=/app/data/training_data
FINETUNE_OUTPUT_DIR=/app/data/finetuned/my_voice
FINETUNE_PROJECT=my_voice
FINETUNE_VQ_BATCH_SIZE=8
FINETUNE_VQ_NUM_WORKERS=2
FINETUNE_BUILD_NUM_WORKERS=8
FINETUNE_LORA_CONFIG=r_8_alpha_16

# HF
HF_ENDPOINT=https://huggingface.co
