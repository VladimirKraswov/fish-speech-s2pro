PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# Build versions
CUDA_VER=12.9.0
PYTORCH_CUDA_TAG=cu129
FISH_SPEECH_REF=main
ENABLE_VLLM_OMNI=true
VLLM_VERSION=0.18.0
VLLM_OMNI_VERSION=

# Published ports
FRONTEND_PORT=7070
GATEWAY_PORT=7777
RENDER_PORT=7778
LIVE_PORT=7779
SGLANG_S2_PORT=7782
PREPROCESS_PORT=7780
FINETUNE_PORT=7781

# Model paths inside containers
MODEL_PATH=/app/data/checkpoints/s2-pro
MODEL_REPO=fishaudio/s2-pro

# Render behavior
RENDER_ENGINE=fish
ENABLE_COMPILE=false
RENDER_STACK_ENABLE_COMPILE=true
COMPILE_CUDAGRAPHS=false
RENDER_STACK_CHUNK_LENGTH=240
OOM_RETRY_CHUNK_CHARS=140
CHUNK_JOIN_SILENCE_MS=90
REFERENCE_MAX_SECONDS=30
REFERENCE_SAMPLE_RATE=24000
REFERENCE_CHANNELS=1
RENDER_MAX_CONCURRENCY=1
RENDER_MAX_QUEUE=8
DTYPE=bfloat16
DEVICE=cuda
MAX_TEXT_LENGTH=1500
CHUNK_LENGTH=240
NORMALIZE_TEXT=true
USE_MEMORY_CACHE=on
TEMPERATURE=0.62
TOP_P=0.88
REPETITION_PENALTY=1.15
SEED=42
VLLM_OMNI_HOST=127.0.0.1
VLLM_OMNI_PORT=8091
VLLM_OMNI_MODEL=fishaudio/s2-pro
VLLM_OMNI_GPU_MEMORY_UTILIZATION=0.9
VLLM_OMNI_START_TIMEOUT=2400
RENDER_HEALTHCHECK_START_PERIOD=2400s
VLLM_OMNI_STAGE_CONFIGS_PATH=
VLLM_OMNI_EXTRA_ARGS=

# SGLang Omni S2 low-TTFB behavior
SGLANG_OMNI_IMAGE=frankleeeee/sglang-omni:dev
SGLANG_S2_MODEL_PATH=/app/data/checkpoints/s2-pro
SGLANG_S2_MODEL_NAME=fishaudio-s2-low-ttfb
SGLANG_S2_BACKEND_PORT=8092
SGLANG_S2_STARTUP_TIMEOUT=2400
SGLANG_S2_REQUEST_TIMEOUT=3600
SGLANG_S2_TARGET_FIRST_BYTE_MS=200
SGLANG_S2_EARLY_WAV_HEADER=true
SGLANG_S2_STREAM_SAMPLE_RATE=44100
SGLANG_S2_WARMUP=true
SGLANG_S2_WARMUP_MAX_NEW_TOKENS=32
SGLANG_S2_MAX_NEW_TOKENS=1024
SGLANG_S2_SHM_SIZE=32g
SGLANG_S2_EXTRA_ARGS=

# Live behavior
LIVE_ENGINE=s2cpp
LIVE_MODEL_PATH=/app/data/live_engine/s2-pro-q8_0.gguf
S2CPP_BIN=/app/data/live_engine/s2
S2CPP_TOKENIZER_PATH=/app/data/live_engine/tokenizer.json
S2CPP_EXTRA_ARGS=

# Fine-tuning
FINETUNE_BASE_MODEL=/app/data/checkpoints/s2-pro
FINETUNE_DATA_DIR=/app/data/training_data
FINETUNE_OUTPUT_DIR=/app/data/finetuned/my_voice
FINETUNE_PROJECT=my_voice
FINETUNE_VQ_BATCH_SIZE=8
FINETUNE_VQ_NUM_WORKERS=2
FINETUNE_BUILD_NUM_WORKERS=8
FINETUNE_LORA_CONFIG=r_8_alpha_16

# Optional
HF_ENDPOINT=https://huggingface.co
CUDA_VISIBLE_DEVICES=0
